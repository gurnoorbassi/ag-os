{
  "policyId": "credential-store-policy-v1",
  "status": "foundation",
  "purpose": "Define how AG OS may reference credentials before any OAuth or live connector work is allowed.",
  "approvedStorageOptions": [
    {
      "id": "future_secure_connector_credential_store",
      "status": "planned",
      "description": "Use an approved connector or platform credential vault that never writes secret values into the AG OS repository."
    },
    {
      "id": "future_local_encrypted_secret_store",
      "status": "planned",
      "description": "Use a local encrypted store only after owner approval, documented key handling, rotation, and revocation rules."
    },
    {
      "id": "future_platform_environment_variables_owner_approved",
      "status": "planned",
      "description": "Use platform environment variables only after owner approval and only when values are never committed, printed, or exported into dashboard data."
    }
  ],
  "forbiddenStorageLocations": [
    "git_repository_files",
    "github_commits",
    "pull_request_bodies",
    "chat_messages",
    "dashboard-data.js",
    "logs",
    "audit_event_secret_values",
    "cost_ledgers",
    "client_records"
  ],
  "rules": {
    "secretValuesAllowedInRepo": false,
    "credentialReferencesOnly": true,
    "ownerApprovalRequiredBeforeUse": true,
    "tokensMayBePrinted": false,
    "tokensMayBeLogged": false,
    "tokensMayBeStoredInDashboardData": false,
    "rotationRequired": true,
    "revocationRequired": true,
    "auditRequired": true
  },
  "firstCandidateUseCase": {
    "provider": "instagram",
    "handle": "@agdigitalz",
    "mode": "connected_draft_only",
    "status": "blocked_until_secure_storage_and_final_owner_approval"
  },
  "createdAt": "2026-07-06T00:00:00.000Z",
  "updatedAt": "2026-07-06T00:00:00.000Z"
}

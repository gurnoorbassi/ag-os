AG_OS_OWNER_TOKEN=generate-a-long-random-value-outside-source-control
AG_OS_HOST=127.0.0.1
AG_OS_PORT=8787
AG_OS_ALLOWED_ORIGIN=https://your-private-dashboard.example.com
# Enable only when the coordinator is reached exclusively through the shipped loopback Caddy proxy.
AG_OS_TRUST_PROXY=false
AG_OS_ANTHROPIC_DAILY_CALL_LIMIT=20
AG_OS_PROVIDER_TIMEOUT_MS=30000
AG_OS_AI_WORKER_TIMEOUT_MS=180000
AG_OS_AI_CRITIC_TIMEOUT_MS=180000
AG_OS_AI_CRITIC_ENABLED=false
AG_OS_AI_CRITIC_REQUIRED=false
AG_OS_AI_CRITIC_APPROVAL_ID=
ANTHROPIC_CRITIC_MODEL=claude-haiku-4-5
ANTHROPIC_CRITIC_INPUT_COST_PER_MILLION_USD=
ANTHROPIC_CRITIC_OUTPUT_COST_PER_MILLION_USD=
AG_OS_MOBILE_APPROVAL_SIGNING_KEY=generate-at-least-32-random-bytes-outside-source-control
AG_OS_MOBILE_APPROVAL_BASE_URL=https://your-private-dashboard.example.com
AG_OS_MOBILE_APPROVAL_DELIVERY=disabled
AG_OS_TELEGRAM_BOT_TOKEN=
AG_OS_TELEGRAM_CHAT_ID=
AG_OS_MOBILE_NOTIFICATION_APPROVAL_ID=
AG_OS_NETLIFY_PREVIEW_SITE_ID=
AG_OS_MONITOR_ALERT_WEBHOOK_URL=
AG_OS_MONITOR_ALERT_TOKEN=
AG_OS_MONITOR_ALERT_FAILURE_THRESHOLD=3
AG_OS_MONITOR_ALERT_TIMEOUT_MS=5000
AG_OS_OWNER_SESSION_COOKIE_SECURE=true
# Caddy environment only; keep separate from the API token.
AG_OS_DASHBOARD_PASSWORD_HASH=generate-with-caddy-hash-password

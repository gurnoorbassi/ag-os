{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/skill.schema.json",
  "title": "AG OS Skill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "recordType",
    "id",
    "name",
    "status",
    "category",
    "appliesTo",
    "procedure",
    "qualityChecklist",
    "commonFailures",
    "evidence",
    "riskNotes",
    "owner",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../schemas/skill.schema.json" },
    "recordType": { "type": "string", "const": "skill" },
    "id": { "type": "string", "pattern": "^skill-[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] },
    "category": {
      "type": "string",
      "enum": ["delivery", "build", "review", "client", "ops"]
    },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "procedure": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "qualityChecklist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "commonFailures": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proofRecords", "timesApplied", "lastAppliedDate"],
      "properties": {
        "sourceLessons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "proofRecords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timesApplied": { "type": "integer", "minimum": 0 },
        "lastAppliedDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "riskNotes": { "type": "string", "minLength": 1 },
    "deprecatedReason": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/owner-preferences.schema.json",
  "title": "AG OS Owner Preference Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId",
    "ownerId",
    "status",
    "rules",
    "preferences",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "profileId": { "type": "string", "pattern": "^owner-preferences-[a-z0-9-]+$" },
    "ownerId": { "type": "string", "pattern": "^owner-[a-z0-9-]+$" },
    "status": { "type": "string", "enum": ["active", "archived"] },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicitStatementsOnly",
        "privateContactDetailsAllowed",
        "sensitivePersonalInfoAllowed",
        "inferredSensitiveInfoAllowed"
      ],
      "properties": {
        "explicitStatementsOnly": { "type": "boolean", "const": true },
        "privateContactDetailsAllowed": { "type": "boolean", "const": false },
        "sensitivePersonalInfoAllowed": { "type": "boolean", "const": false },
        "inferredSensitiveInfoAllowed": { "type": "boolean", "const": false }
      }
    },
    "preferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["preferenceId", "statement", "category"],
        "properties": {
          "preferenceId": { "type": "string", "pattern": "^pref-[a-z0-9-]+$" },
          "statement": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["quality", "cost", "stack", "governance", "workflow", "product"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

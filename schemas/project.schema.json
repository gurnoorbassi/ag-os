{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/project.schema.json",
  "title": "AG Digitalz OS Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "status",
    "owner",
    "projectType",
    "managementMode",
    "goal",
    "scope",
    "outOfScope",
    "trustLevel",
    "stack",
    "risks",
    "approvalRequiredFor",
    "qualityGates",
    "securityReview",
    "costTracking",
    "deploymentPlan",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "template": { "type": "boolean", "const": true },
    "id": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 3 },
    "status": { "type": "string", "enum": ["idea", "planned", "active", "blocked", "paused", "complete", "archived"] },
    "owner": { "type": "string", "minLength": 1 },
    "projectType": { "type": "string", "enum": ["internal_project", "product_project", "ag_os_core"] },
    "managementMode": {
      "type": "string",
      "enum": ["observe_only", "read_only", "active_build", "managed_staging", "production_managed"]
    },
    "goal": { "type": "string", "minLength": 1 },
    "knownFacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "scope": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "outOfScope": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "trustLevel": { "type": "integer", "minimum": 0, "maximum": 4 },
    "stack": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "mitigation"],
        "properties": {
          "risk": { "type": "string", "minLength": 1 },
          "mitigation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "approvalRequiredFor": { "type": "array", "items": { "type": "string" } },
    "qualityGates": { "type": "array", "items": { "type": "string" } },
    "securityReview": { "type": "string", "minLength": 1 },
    "costTracking": { "type": "string", "minLength": 1 },
    "deploymentPlan": { "type": "string", "minLength": 1 },
    "ownerWorkspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "sourceControlStatus",
        "sourceControlDetail",
        "operations"
      ],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "liveUrl": { "type": "string", "format": "uri" },
        "liveLabel": { "type": "string", "minLength": 1 },
        "previewMode": { "type": "string", "enum": ["new_tab", "embedded"] },
        "previewReason": { "type": "string", "minLength": 1 },
        "sourceControlStatus": { "type": "string", "enum": ["connected", "approval_required", "setup_needed"] },
        "sourceControlDetail": { "type": "string", "minLength": 1 },
        "repositoryUrl": { "type": "string", "format": "uri" },
        "repositoryFullName": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "repositoryVisibility": { "type": "string", "enum": ["private", "public"] },
        "defaultBranch": { "type": "string", "minLength": 1 },
        "adapters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["adapterId", "status", "target", "detail"],
            "properties": {
              "adapterId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "status": { "type": "string", "enum": ["connected", "ready", "approval_required", "setup_required", "blocked"] },
              "target": { "type": "string", "minLength": 1 },
              "detail": { "type": "string", "minLength": 1 }
            }
          }
        },
        "operations": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

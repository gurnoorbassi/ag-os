{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/command-intake.schema.json",
  "title": "AG OS Command Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "commandIntakeId",
    "status",
    "rawCommand",
    "normalizedCommand",
    "commandCategory",
    "riskLevel",
    "classification",
    "plannedOutput",
    "nextRecord",
    "safety",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "commandIntakeId": {
      "type": "string",
      "pattern": "^command-intake-[a-z0-9-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "template",
        "classified",
        "planning",
        "blocked",
        "converted_to_job",
        "cancelled"
      ]
    },
    "rawCommand": {
      "type": "string",
      "minLength": 1
    },
    "normalizedCommand": {
      "type": "string",
      "minLength": 1
    },
    "commandCategory": {
      "type": "string",
      "enum": [
        "discuss_only",
        "plan_only",
        "build",
        "deploy_staging",
        "deploy_production",
        "connect_service",
        "change_domain",
        "send_message",
        "stop_all",
        "rollback",
        "audit"
      ]
    },
    "projectId": {
      "type": "string"
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4",
        "R5",
        "R6"
      ]
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiresPlan",
        "requiresApproval",
        "requiresLiveService",
        "requiresDeployment",
        "requiresDomainChange",
        "requiresPaidAction",
        "requiresProductionData"
      ],
      "properties": {
        "requiresPlan": {
          "type": "boolean"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "requiresLiveService": {
          "type": "boolean"
        },
        "requiresDeployment": {
          "type": "boolean"
        },
        "requiresDomainChange": {
          "type": "boolean"
        },
        "requiresPaidAction": {
          "type": "boolean"
        },
        "requiresProductionData": {
          "type": "boolean"
        }
      }
    },
    "productContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productType",
        "archetypeId",
        "archetypeRegistered",
        "archetypeGap"
      ],
      "properties": {
        "productType": {
          "type": "string",
          "minLength": 1
        },
        "archetypeId": {
          "type": ["string", "null"]
        },
        "archetypeRegistered": {
          "type": "boolean"
        },
        "archetypeGap": {
          "type": ["string", "null"]
        }
      }
    },
    "understanding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producedBy",
        "inferredBusinessObjective",
        "productArchetype",
        "targetUser",
        "successCriteria",
        "criticalUnknowns",
        "confidence",
        "assumptions",
        "ownerConstraints"
      ],
      "properties": {
        "producedBy": {
          "type": "string",
          "minLength": 1
        },
        "inferredBusinessObjective": {
          "type": "string",
          "minLength": 1
        },
        "productArchetype": {
          "type": "string",
          "minLength": 1
        },
        "targetUser": {
          "type": "string",
          "minLength": 1
        },
        "successCriteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "criticalUnknowns": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ownerConstraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "executionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapterId", "operation"],
      "properties": {
        "adapterId": { "type": "string", "enum": ["github-private-repository", "github-draft-pr", "n8n-disabled-workflow", "n8n-workflow-control", "netlify-staging", "netlify-continuous-deployment", "production-deployment", "social-publishing", "dns-change"] },
        "operation": { "type": "string", "enum": ["create_private_repository", "create_draft_pr", "create_disabled_workflow", "activate_workflow", "deactivate_workflow", "create_draft_deploy", "link_github_repository", "deploy_exact_commit", "publish_instagram_image", "upsert_cloudflare_record"] },
        "repository": {
          "type": ["object", "string"],
          "additionalProperties": false,
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "id": { "type": "integer", "minimum": 1 },
            "private": { "type": "boolean" },
            "installationId": { "type": "integer", "minimum": 1 }
          }
        },
        "projectId": { "type": "string", "minLength": 1 },
        "projectRecordPath": { "type": "string", "pattern": "^\\.codex/projects/[a-z0-9-]+\\.json$" },
        "description": { "type": "string", "maxLength": 350 },
        "baseBranch": { "type": "string", "minLength": 1 },
        "expectedBaseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "branch": { "type": "string", "pattern": "^codex/[A-Za-z0-9][A-Za-z0-9._/-]*$" },
        "sourceDirectory": { "type": "string", "pattern": "^\\.codex/workspaces/" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "body": { "type": "string" },
        "baseUrl": { "type": "string", "pattern": "^https://.+/api/v1/?$" },
        "workflow": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "nodes", "connections"],
          "properties": {
            "name": { "type": "string", "minLength": 1, "maxLength": 120 },
            "nodes": { "type": "array", "minItems": 1, "maxItems": 100 },
            "connections": { "type": "object" },
            "settings": { "type": "object" },
            "active": { "type": "boolean", "const": false }
          }
        },
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9-]{3,80}$" },
        "siteName": { "type": "string", "minLength": 1 },
        "draft": { "type": "boolean", "const": true },
        "buildCommand": { "type": "string", "minLength": 1 },
        "publishDirectory": { "type": "string", "minLength": 1 },
        "stopBuilds": { "type": "boolean", "const": true },
        "workflowId": { "type": "string", "minLength": 1 },
        "expectedWorkflowName": { "type": "string", "minLength": 1 },
        "expectedWorkflowDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "profileId": { "type": "string", "minLength": 1 },
        "commitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "targetEnvironment": { "type": "string", "const": "production" },
        "expectedService": { "type": "string", "minLength": 1 },
        "jobId": { "type": "string", "minLength": 1 },
        "approvalId": { "type": "string", "minLength": 1 },
        "graphBaseUrl": { "type": "string", "pattern": "^https://graph\\.facebook\\.com/v[0-9]+\\.[0-9]+$" },
        "accountId": { "type": "string", "pattern": "^[0-9]{5,40}$" },
        "expectedUsername": { "type": "string", "minLength": 1 },
        "mediaUrl": { "type": "string", "pattern": "^https://" },
        "caption": { "type": "string", "minLength": 1, "maxLength": 2200 },
        "contentDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "zoneId": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
        "recordId": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
        "recordDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "record": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name", "content"],
          "properties": {
            "type": { "type": "string", "enum": ["A", "AAAA", "CNAME", "TXT", "MX", "CAA"] },
            "name": { "type": "string", "minLength": 1 },
            "content": { "type": "string", "minLength": 1 },
            "ttl": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "proxied": { "type": "boolean" },
            "priority": { "type": "integer", "minimum": 0, "maximum": 65535 }
          }
        }
      }
    },
    "plannedOutput": {
      "type": "string",
      "minLength": 1
    },
    "blockedReason": {
      "type": "string"
    },
    "nextRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jobId",
        "planId"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "planId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executesCommand",
        "createsLiveSideEffect",
        "usesCredentials",
        "callsConnector"
      ],
      "properties": {
        "executesCommand": {
          "type": "boolean",
          "const": false
        },
        "createsLiveSideEffect": {
          "type": "boolean",
          "const": false
        },
        "usesCredentials": {
          "type": "boolean",
          "const": false
        },
        "callsConnector": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    }
  }
}

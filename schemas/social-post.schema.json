{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/social-post.schema.json",
  "title": "AG OS Social Post",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "postId",
    "recordType",
    "projectId",
    "clientId",
    "engagementId",
    "platform",
    "lifecycleState",
    "ownerDraftApprovalStatus",
    "postingPermission",
    "schedulingPermission",
    "analyticsPermission",
    "credentialRequired",
    "sourceRecords",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../../schemas/social-post.schema.json" },
    "postId": { "type": "string", "pattern": "^social-post-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "recordType": { "type": "string", "const": "social_post" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "clientId": { "type": "string", "pattern": "^client-[a-z0-9-]+$" },
    "engagementId": { "type": "string", "pattern": "^engagement-[a-z0-9-]+$" },
    "platform": { "type": "string", "enum": ["Instagram", "TikTok", "YouTube Shorts", "LinkedIn"] },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "draft",
        "owner_approved_draft",
        "ready_for_oauth",
        "connected_draft_only",
        "ready_for_live_publish_approval",
        "owner_approved_for_single_publish",
        "publish_in_progress",
        "published",
        "publish_failed",
        "scheduled_pending_approval",
        "scheduled",
        "cancelled",
        "blocked"
      ]
    },
    "ownerDraftApprovalStatus": { "type": "string", "enum": ["not_requested", "owner_approved_draft", "rejected", "revision_needed"] },
    "postingPermission": { "type": "string", "enum": ["blocked", "single_post_approval_required", "approved_for_exact_post"] },
    "schedulingPermission": { "type": "string", "enum": ["blocked", "approval_required", "approved"] },
    "analyticsPermission": { "type": "string", "enum": ["blocked", "approval_required", "approved"] },
    "credentialRequired": { "type": "boolean" },
    "approvedBy": { "type": "string", "pattern": "^owner-[a-z0-9-]+$" },
    "sourceRecords": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/capability-registry.schema.json",
  "title": "AG Digitalz OS Capability Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "registryVersion",
    "registryType",
    "status",
    "capabilities",
    "allowedCapabilityTypes",
    "rules",
    "notes"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../schemas/capability-registry.schema.json" },
    "registryVersion": { "type": "integer", "minimum": 1 },
    "registryType": { "type": "string", "const": "capability-registry" },
    "status": { "type": "string", "enum": ["foundation", "active", "archived"] },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "type",
          "owner",
          "status",
          "safetyTier",
          "approvalRequired"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^capability-[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": [
              "discussion",
              "planning",
              "local_build",
              "validation",
              "registry_management",
              "documentation",
              "approval_packet",
              "connector_execution"
            ]
          },
          "provenBy": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "boundaries": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "owner": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["planned", "approved", "active", "paused", "retired"] },
          "safetyTier": { "type": "string", "enum": ["tier_0", "tier_1", "tier_2", "owner_approval_required"] },
          "approvalRequired": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "allowedCapabilityTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "discussion",
          "planning",
          "local_build",
          "validation",
          "registry_management",
          "documentation",
          "approval_packet"
        ]
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialsAllowed",
        "liveActionsAllowedByDefault",
        "ownerApprovalRequiredForLiveActions",
        "ownerApprovalRequiredForPaidActions",
        "productionDataAllowed",
        "customerDataAllowed",
        "deploymentAllowedByDefault"
      ],
      "properties": {
        "credentialsAllowed": { "type": "boolean", "const": false },
        "liveActionsAllowedByDefault": { "type": "boolean", "const": false },
        "ownerApprovalRequiredForLiveActions": { "type": "boolean", "const": true },
        "ownerApprovalRequiredForPaidActions": { "type": "boolean", "const": true },
        "productionDataAllowed": { "type": "boolean", "const": false },
        "customerDataAllowed": { "type": "boolean", "const": false },
        "deploymentAllowedByDefault": { "type": "boolean", "const": false }
      }
    },
    "notes": { "type": "string", "minLength": 1 }
  }
}

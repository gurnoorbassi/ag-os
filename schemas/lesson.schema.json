{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/lesson.schema.json",
  "title": "AG OS Lesson",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lessonId",
    "title",
    "lesson",
    "sources",
    "scope",
    "confidence",
    "status",
    "owner",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "lessonId": { "type": "string", "pattern": "^lesson-[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "lesson": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": {
      "type": "string",
      "enum": ["personal", "project", "client", "company", "agent_shared", "worker_specific"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "accepted", "rejected", "archived"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string" },
    "appliesTo": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceScoreId": { "type": "string", "pattern": "^quality-score-[a-z0-9-]+$" },
    "promotedToSkill": { "type": "string", "pattern": "^skill-[a-z0-9-]+$" },
    "generatedBy": { "type": "string", "minLength": 1 },
    "whyThisMatters": { "type": "string", "minLength": 1 },
    "whenToUse": { "type": "string", "minLength": 1 },
    "whenNotToUse": { "type": "string", "minLength": 1 },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvalId", "approvedBy", "approvedAt", "evidence", "sourceCandidatePath"],
      "properties": {
        "approvalId": { "type": "string", "pattern": "^approval-[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceCandidatePath": { "type": "string", "minLength": 1 }
      }
    },
    "rejection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rejectedBy", "rejectedAt", "reason", "sourceCandidatePath"],
      "properties": {
        "rejectedBy": { "type": "string", "minLength": 1 },
        "rejectedAt": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "sourceCandidatePath": { "type": "string", "minLength": 1 }
      }
    },
    "runtimeUse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedForPlanning",
        "allowedForCritic",
        "allowedForBuilder",
        "allowedForWorkers",
        "grantsPermission",
        "liveActionsAllowed",
        "approvalBypassAllowed"
      ],
      "properties": {
        "allowedForPlanning": { "type": "boolean" },
        "allowedForCritic": { "type": "boolean" },
        "allowedForBuilder": { "type": "boolean" },
        "allowedForWorkers": { "type": "boolean" },
        "grantsPermission": { "type": "boolean", "const": false },
        "liveActionsAllowed": { "type": "boolean", "const": false },
        "approvalBypassAllowed": { "type": "boolean", "const": false }
      }
    },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

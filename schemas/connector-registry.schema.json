{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/connector-registry.schema.json",
  "title": "AG Digitalz OS Connector Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "registryVersion",
    "registryType",
    "status",
    "connectors",
    "availableButNotConnected",
    "rules"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../schemas/connector-registry.schema.json" },
    "registryVersion": { "type": "integer", "minimum": 1 },
    "registryType": { "type": "string", "const": "connector-registry" },
    "status": { "type": "string", "enum": ["foundation", "active", "archived"] },
    "connectors": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "provider",
          "mcpNamespace",
          "connectionStatus",
          "verificationSource",
          "allowedCapabilities",
          "approvalRequiredFor",
          "prohibitedActions",
          "notes"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^connector-[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "mcpNamespace": { "type": "string", "pattern": "^mcp__[a-z0-9_]+(?:__[a-z0-9_]+)*$" },
          "connectionStatus": { "type": "string", "const": "connected" },
          "verificationSource": { "type": "string", "minLength": 1 },
          "allowedCapabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "approvalRequiredFor": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "prohibitedActions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "availableButNotConnected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "provider", "connectionStatus", "intendedUse", "notes"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "connectionStatus": { "type": "string", "const": "available_not_connected" },
          "intendedUse": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialsAllowed",
        "liveCallsAllowedByDefault",
        "deploymentsAllowedByDefault",
        "workflowActivationAllowedByDefault",
        "domainChangesAllowedByDefault",
        "paidActionsAllowedByDefault",
        "productionDataAllowedByDefault"
      ],
      "properties": {
        "credentialsAllowed": { "type": "boolean", "const": false },
        "liveCallsAllowedByDefault": { "type": "boolean", "const": false },
        "deploymentsAllowedByDefault": { "type": "boolean", "const": false },
        "workflowActivationAllowedByDefault": { "type": "boolean", "const": false },
        "domainChangesAllowedByDefault": { "type": "boolean", "const": false },
        "paidActionsAllowedByDefault": { "type": "boolean", "const": false },
        "productionDataAllowedByDefault": { "type": "boolean", "const": false }
      }
    }
  }
}

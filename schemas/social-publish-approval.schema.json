{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/social-publish-approval.schema.json",
  "title": "AG OS Social Publish Approval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "publishApprovalId",
    "recordType",
    "status",
    "approvalId",
    "projectId",
    "clientId",
    "engagementId",
    "targetPlatform",
    "targetHandle",
    "allowedAction",
    "exactPostOnly",
    "schedulingAllowed",
    "analyticsAllowed",
    "dmCommentsAllowed",
    "n8nActivationAllowed",
    "postingPermissionSource",
    "prohibitedActions",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../../schemas/social-publish-approval.schema.json" },
    "publishApprovalId": { "type": "string", "pattern": "^social-publish-approval-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "recordType": { "type": "string", "const": "social_publish_approval" },
    "status": { "type": "string", "enum": ["template", "approved", "used", "expired", "revoked", "blocked"] },
    "approvalId": { "type": "string", "pattern": "^approval-[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "clientId": { "type": "string", "pattern": "^client-[a-z0-9-]+$" },
    "engagementId": { "type": "string", "pattern": "^engagement-[a-z0-9-]+$" },
    "targetPlatform": { "type": "string", "enum": ["Instagram", "TikTok", "YouTube Shorts", "LinkedIn"] },
    "targetHandle": { "type": "string", "minLength": 1 },
    "postId": { "type": "string", "pattern": "^social-post-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "allowedAction": { "type": "string", "enum": ["publish_single_post", "schedule_posts", "analytics_readonly"] },
    "exactPostOnly": { "type": "boolean" },
    "schedulingAllowed": { "type": "boolean" },
    "analyticsAllowed": { "type": "boolean" },
    "dmCommentsAllowed": { "type": "boolean", "const": false },
    "n8nActivationAllowed": { "type": "boolean", "const": false },
    "postingPermissionSource": { "type": "string", "enum": ["owner_approval_lock_only"] },
    "prohibitedActions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

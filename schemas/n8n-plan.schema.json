{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/n8n-plan.schema.json",
  "title": "AG OS n8n Approval-Package Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "n8nPlanId",
    "status",
    "mode",
    "connectorId",
    "projectId",
    "targetWorkflowName",
    "workflowPurpose",
    "riskLevel",
    "proposedAction",
    "draftOnlyScope",
    "expectedWorkflowBehavior",
    "expectedNodes",
    "placeholderTestPayload",
    "credentialPolicy",
    "preExecutionChecks",
    "validationPlan",
    "costEstimate",
    "rollbackPlan",
    "stopConditions",
    "safety",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "n8nPlanId": { "type": "string", "pattern": "^n8n-plan-[a-z0-9-]+$" },
    "status": { "type": "string", "const": "planned" },
    "mode": { "type": "string", "const": "approval_package_only" },
    "connectorId": { "type": "string", "const": "connector-n8n-mcp" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "targetWorkflowName": { "type": "string", "minLength": 1 },
    "workflowPurpose": { "type": "string", "minLength": 1 },
    "riskLevel": { "type": "string", "enum": ["R4", "R5"] },
    "proposedAction": { "type": "string", "minLength": 1 },
    "draftOnlyScope": { "type": "object" },
    "expectedWorkflowBehavior": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "expectedNodes": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "placeholderTestPayload": { "type": "object" },
    "credentialPolicy": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "preExecutionChecks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validationPlan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "costEstimate": { "type": "object" },
    "rollbackPlan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "stopConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "safety": {
      "type": "object",
      "required": [
        "executesN8nAction",
        "createsWorkflow",
        "activatesWorkflow",
        "connectsCredentials",
        "sendsMessages",
        "callsRealExternalServices",
        "touchesProductionWorkflow",
        "usesPaidAction",
        "touchesProductionData",
        "touchesCustomerData"
      ],
      "properties": {
        "executesN8nAction": { "type": "boolean", "const": false },
        "createsWorkflow": { "type": "boolean", "const": false },
        "activatesWorkflow": { "type": "boolean", "const": false },
        "connectsCredentials": { "type": "boolean", "const": false },
        "sendsMessages": { "type": "boolean", "const": false },
        "callsRealExternalServices": { "type": "boolean", "const": false },
        "touchesProductionWorkflow": { "type": "boolean", "const": false },
        "touchesLeadGenWorkflow": { "type": "boolean", "const": false },
        "touchesAiReceptionistWorkflow": { "type": "boolean", "const": false },
        "usesPaidAction": { "type": "boolean", "const": false },
        "touchesProductionData": { "type": "boolean", "const": false },
        "touchesCustomerData": { "type": "boolean", "const": false }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

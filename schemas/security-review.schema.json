{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/security-review.schema.json",
  "title": "AG Digitalz OS Security Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "projectId", "status", "dataSensitivity", "accessChanges", "findings", "approvalRequired", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "pattern": "^security-[a-z0-9-]+$" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "status": { "type": "string", "enum": ["planned", "in_review", "approved", "blocked", "waived"] },
    "dataSensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "customer_data",
        "production_data",
        "secrets"
      ]
    },
    "accessChanges": { "type": "array", "items": { "type": "string" } },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary", "severity", "status"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "status": { "type": "string", "enum": ["open", "accepted", "fixed", "not_applicable"] }
        }
      }
    },
    "approvalRequired": { "type": "boolean" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

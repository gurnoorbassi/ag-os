{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/lesson-promotion.schema.json",
  "title": "AG OS Lesson Promotion Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "recordType",
    "promotionId",
    "candidateLessonId",
    "status",
    "scope",
    "evidence",
    "requiredAction",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../../schemas/lesson-promotion.schema.json" },
    "recordType": {
      "type": "string",
      "enum": ["lesson_promotion", "lesson_rejection", "lesson_conflict"]
    },
    "promotionId": { "type": "string", "pattern": "^lesson-[a-z0-9-]+$" },
    "candidateLessonId": { "type": "string", "pattern": "^lesson-[a-z0-9-]+$" },
    "acceptedLessonId": { "type": "string", "pattern": "^lesson-[a-z0-9-]+$" },
    "existingLessonId": { "type": "string", "pattern": "^lesson-[a-z0-9-]+$" },
    "approvalId": { "type": "string", "pattern": "^approval-[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "approvedBy": { "type": "string", "minLength": 1 },
    "rejectedBy": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pending_owner_approval", "approved", "rejected", "blocked", "archived"]
    },
    "scope": {
      "type": "string",
      "enum": ["personal", "project", "client", "company", "agent_shared", "worker_specific"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "requiredAction": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/watchdog-policy.schema.json",
  "title": "AG Digitalz OS Watchdog Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "policyVersion",
    "policyType",
    "status",
    "defaults",
    "plannedCheckTypes",
    "approvalRules",
    "allowedFoundationActions",
    "blockedFoundationActions",
    "notes"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../schemas/watchdog-policy.schema.json" },
    "policyVersion": { "type": "integer", "minimum": 1 },
    "policyType": { "type": "string", "const": "watchdog-os-policy" },
    "status": { "type": "string", "enum": ["foundation", "active", "archived"] },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "monitoringEnabled",
        "liveChecksAllowed",
        "mutationsAllowed",
        "notificationsAllowed",
        "paidMonitoringAllowed"
      ],
      "properties": {
        "monitoringEnabled": { "type": "boolean", "const": false },
        "liveChecksAllowed": { "type": "boolean", "const": false },
        "mutationsAllowed": { "type": "boolean", "const": false },
        "notificationsAllowed": { "type": "boolean", "const": false },
        "paidMonitoringAllowed": { "type": "boolean", "const": false }
      }
    },
    "plannedCheckTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "approvalRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "liveMonitoringRequiresOwnerApproval",
        "externalNotificationsRequireOwnerApproval",
        "paidMonitoringRequiresOwnerApproval",
        "mutationsRequireOwnerApproval",
        "productionTargetsRequireOwnerApproval"
      ],
      "properties": {
        "liveMonitoringRequiresOwnerApproval": { "type": "boolean", "const": true },
        "externalNotificationsRequireOwnerApproval": { "type": "boolean", "const": true },
        "paidMonitoringRequiresOwnerApproval": { "type": "boolean", "const": true },
        "mutationsRequireOwnerApproval": { "type": "boolean", "const": true },
        "productionTargetsRequireOwnerApproval": { "type": "boolean", "const": true }
      }
    },
    "allowedFoundationActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "blockedFoundationActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "notes": { "type": "string", "minLength": 1 }
  }
}

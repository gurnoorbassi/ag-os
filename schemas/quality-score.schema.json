{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/quality-score.schema.json",
  "title": "AG OS Quality Score",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scoreId",
    "status",
    "scoreType",
    "projectId",
    "outputType",
    "archetypeId",
    "sourcePlanPath",
    "archetypeFile",
    "checklistItemsEvaluated",
    "dimensions",
    "overallScore",
    "meetsBar",
    "reviewStatus",
    "evidence",
    "generatedBy",
    "limitations",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "scoreId": { "type": "string", "pattern": "^quality-score-[a-z0-9-]+$" },
    "status": {
      "type": "string",
      "enum": ["candidate", "accepted", "archived"]
    },
    "scoreType": {
      "type": "string",
      "enum": ["plan_quality_score", "product_quality_score"]
    },
    "projectId": { "type": "string", "minLength": 1 },
    "planId": { "type": "string" },
    "sourcePlanPath": { "type": "string", "minLength": 1 },
    "outputType": {
      "type": "string",
      "enum": [
        "website",
        "app",
        "crm",
        "social_media_system",
        "presentation",
        "dashboard",
        "automation",
        "workflow",
        "prompt",
        "code",
        "docs",
        "deployment"
      ]
    },
    "archetypeId": { "type": "string", "minLength": 1 },
    "archetypeFile": { "type": "string", "minLength": 1 },
    "checklistItemsEvaluated": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completeness",
        "craft",
        "maintainability",
        "ux",
        "security",
        "performance",
        "ownerAcceptance",
        "archetypeFit",
        "costDiscipline"
      ],
      "properties": {
        "completeness": { "type": "integer", "minimum": 0, "maximum": 10 },
        "craft": { "type": "integer", "minimum": 0, "maximum": 10 },
        "maintainability": { "type": "integer", "minimum": 0, "maximum": 10 },
        "ux": { "type": "integer", "minimum": 0, "maximum": 10 },
        "security": { "type": "integer", "minimum": 0, "maximum": 10 },
        "performance": { "type": "integer", "minimum": 0, "maximum": 10 },
        "ownerAcceptance": { "type": "integer", "minimum": 0, "maximum": 10 },
        "archetypeFit": { "type": "integer", "minimum": 0, "maximum": 10 },
        "costDiscipline": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 10 },
    "meetsBar": { "type": "boolean" },
    "reviewStatus": {
      "type": "string",
      "enum": ["pass", "review", "fail"]
    },
    "improvementRecommendations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "lessonCandidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "generatedBy": { "type": "string", "minLength": 1 },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

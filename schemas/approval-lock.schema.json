{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/approval-lock.schema.json",
  "title": "AG Digitalz OS Approval Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approvalId",
    "status",
    "ownerId",
    "requestedBy",
    "approvedBy",
    "commandCategory",
    "requestedAction",
    "target",
    "scope",
    "riskLevel",
    "dataClass",
    "approvalRequiredFor",
    "approvedActions",
    "prohibitedActions",
    "revocationPath",
    "evidence",
    "approvedAt",
    "expiresAt",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "approvalId": { "type": "string", "pattern": "^approval-[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "status": { "type": "string", "enum": ["approved", "expired", "revoked"] },
    "approvalKind": { "type": "string", "enum": ["single_action", "standing"] },
    "actionClass": { "type": "string", "minLength": 1 },
    "inclusionCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "maxUses": { "type": "integer", "minimum": 1 },
    "usageAuditRequired": { "type": "boolean" },
    "revocableImmediately": { "type": "boolean" },
    "ownerId": { "type": "string", "pattern": "^owner-[a-z0-9-]+$" },
    "requestedBy": { "type": "string", "minLength": 1 },
    "approvedBy": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "taskId": { "type": "string", "pattern": "^task-[a-z0-9-]+$" },
    "commandCategory": {
      "type": "string",
      "enum": [
        "discuss_only",
        "plan_only",
        "build",
        "deploy_staging",
        "deploy_production",
        "connect_service",
        "change_domain",
        "send_message",
        "stop_all",
        "rollback",
        "audit"
      ]
    },
    "requestedAction": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "credentialRefId": { "type": "string", "pattern": "^credential-ref-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "requestedPermissions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "excludedPermissions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "riskLevel": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4", "R5", "R6"] },
    "dataClass": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "customer_data",
        "production_data",
        "secrets"
      ]
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "maxUsd"],
      "properties": {
        "required": { "type": "boolean" },
        "maxUsd": { "type": "number", "minimum": 0 },
        "usageLedgerRef": { "type": "string", "minLength": 1 }
      }
    },
    "approvalRequiredFor": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "approvedActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "prohibitedActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "revocationPath": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "reference", "verified"],
        "properties": {
          "type": { "type": "string", "enum": ["owner_instruction", "pr_link", "ci_status", "validation_output", "review_note", "other"] },
          "reference": { "type": "string", "minLength": 1 },
          "verified": { "type": "boolean" }
        }
      }
    },
    "approvalText": { "type": "string", "minLength": 1 },
    "approvedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

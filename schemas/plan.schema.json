{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/plan.schema.json",
  "title": "AG OS Plan Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "jobId",
    "commandId",
    "projectId",
    "summary",
    "riskLevel",
    "estimatedCostUsd",
    "tools",
    "tasks",
    "approvalGates",
    "expectedOutput",
    "stopConditions",
    "safety",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "planId": {
      "type": "string",
      "pattern": "^plan-[a-z0-9-]+$"
    },
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4",
        "R5",
        "R6"
      ]
    },
    "estimatedCostUsd": {
      "type": "number",
      "minimum": 0
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId",
          "description",
          "owner",
          "status"
        ],
        "properties": {
          "taskId": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "blocked",
              "done"
            ]
          }
        }
      }
    },
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productArchetype"
      ],
      "properties": {
        "productArchetype": {
          "type": "string",
          "minLength": 1
        },
        "appliedLessons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ownerPreferencesUsed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stackChoice": {
          "type": "string",
          "minLength": 1
        },
        "qualityBar": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "approvalGates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gateId",
          "approvalRequired",
          "reason"
        ],
        "properties": {
          "gateId": {
            "type": "string",
            "minLength": 1
          },
          "approvalRequired": {
            "type": "boolean"
          },
          "approvalId": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expectedOutput": {
      "type": "string",
      "minLength": 1
    },
    "stopConditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionAuthorized",
        "liveServiceUseAllowed",
        "deploymentAllowed",
        "productionDataAllowed",
        "paidActionAllowed"
      ],
      "properties": {
        "executionAuthorized": {
          "type": "boolean",
          "const": false
        },
        "liveServiceUseAllowed": {
          "type": "boolean",
          "const": false
        },
        "deploymentAllowed": {
          "type": "boolean",
          "const": false
        },
        "productionDataAllowed": {
          "type": "boolean",
          "const": false
        },
        "paidActionAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    }
  }
}

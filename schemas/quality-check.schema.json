{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/quality-check.schema.json",
  "title": "AG Digitalz OS Quality Check",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "projectId", "status", "checks", "evidence", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "pattern": "^quality-[a-z0-9-]+$" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "status": { "type": "string", "enum": ["planned", "passing", "failing", "waived"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["planned", "passing", "failing", "waived"] },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/netlify-plan.schema.json",
  "title": "AG OS Netlify Approval-Package Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "netlifyPlanId",
    "status",
    "mode",
    "connectorId",
    "projectId",
    "targetRepository",
    "targetBranch",
    "targetMainSha",
    "riskLevel",
    "proposedAction",
    "stagingScope",
    "buildSettings",
    "preExecutionChecks",
    "validationPlan",
    "costEstimate",
    "rollbackPlan",
    "stopConditions",
    "safety",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "netlifyPlanId": { "type": "string", "pattern": "^netlify-plan-[a-z0-9-]+$" },
    "status": { "type": "string", "const": "planned" },
    "mode": { "type": "string", "const": "approval_package_only" },
    "connectorId": { "type": "string", "const": "connector-netlify-mcp" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "targetRepository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "targetBranch": { "type": "string", "minLength": 1 },
    "targetMainSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "targetPullRequest": { "type": "string", "minLength": 1 },
    "riskLevel": { "type": "string", "enum": ["R4", "R5"] },
    "proposedAction": { "type": "string", "minLength": 1 },
    "stagingScope": { "type": "object" },
    "buildSettings": { "type": "object" },
    "securityCheck": { "type": "object" },
    "preExecutionChecks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validationPlan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "costEstimate": { "type": "object" },
    "rollbackPlan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "stopConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "safety": {
      "type": "object",
      "required": [
        "deploysProduction",
        "changesDomain",
        "changesDns",
        "usesPaidAction",
        "usesCredentialsInRepo"
      ],
      "properties": {
        "executesNetlifyAction": { "type": "boolean", "const": false },
        "createsSite": { "type": "boolean", "const": false },
        "deploysStaging": { "type": "boolean", "const": false },
        "deploysProduction": { "type": "boolean", "const": false },
        "changesDomain": { "type": "boolean", "const": false },
        "changesDns": { "type": "boolean", "const": false },
        "usesPaidAction": { "type": "boolean", "const": false },
        "usesCredentialsInRepo": { "type": "boolean", "const": false },
        "connectsSocialAccounts": { "type": "boolean", "const": false },
        "postsContent": { "type": "boolean", "const": false },
        "schedulesContent": { "type": "boolean", "const": false },
        "usesAnalyticsApi": { "type": "boolean", "const": false },
        "activatesN8n": { "type": "boolean", "const": false },
        "touchesProductionData": { "type": "boolean", "const": false },
        "touchesCustomerData": { "type": "boolean", "const": false },
        "touchesRealClientData": { "type": "boolean", "const": false },
        "exposesPrivateClientData": { "type": "boolean", "const": false },
        "exposesProductionCustomerData": { "type": "boolean", "const": false },
        "performsLiveConnectorWrites": { "type": "boolean", "const": false },
        "performsSocialActions": { "type": "boolean", "const": false },
        "touchesLeadGen": { "type": "boolean", "const": false },
        "touchesAiReceptionist": { "type": "boolean", "const": false },
        "changesConstitution": { "type": "boolean", "const": false }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

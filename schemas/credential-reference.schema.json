{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/credential-reference.schema.json",
  "title": "AG OS Credential Reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "credentialRefId",
    "provider",
    "purpose",
    "storageBackend",
    "secretValueStoredInRepo",
    "repoSafe",
    "ownerApprovalRequired",
    "rotationPolicy",
    "revocationPolicy",
    "auditRequirement",
    "allowedConnectors",
    "prohibitedUses"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "../../schemas/credential-reference.schema.json"
    },
    "credentialRefId": {
      "type": "string",
      "pattern": "^credential-ref-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "approved_reference", "active_reference", "revoked", "archived"]
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "storageBackend": {
      "type": "string",
      "enum": [
        "future_secure_connector_credential_store",
        "future_local_encrypted_secret_store",
        "future_platform_environment_variables_owner_approved"
      ]
    },
    "secretValueStoredInRepo": {
      "type": "boolean",
      "const": false
    },
    "repoSafe": {
      "type": "boolean",
      "const": true
    },
    "ownerApprovalRequired": {
      "type": "boolean",
      "const": true
    },
    "rotationPolicy": {
      "type": "string",
      "minLength": 1
    },
    "revocationPolicy": {
      "type": "string",
      "minLength": 1
    },
    "auditRequirement": {
      "type": "string",
      "minLength": 1
    },
    "allowedConnectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^connector-[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "prohibitedUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    }
  }
}

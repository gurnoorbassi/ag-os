{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-digitalz.local/schemas/owner.schema.json",
  "title": "AG Digitalz OS Owner",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "role",
    "authorityLevel",
    "status",
    "responsibilities",
    "approvalScopes",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^owner-[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "role": {
      "type": "string",
      "enum": ["business_owner", "project_owner", "technical_owner", "security_owner", "cost_owner", "agent_owner", "reviewer"]
    },
    "authorityLevel": { "type": "string", "enum": ["final", "delegated", "review_only"] },
    "status": { "type": "string", "enum": ["active", "inactive"] },
    "responsibilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "approvalScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "constitution",
          "projects",
          "tasks",
          "agents",
          "connectors",
          "capabilities",
          "live_services",
          "deployments",
          "domains",
          "credentials",
          "data",
          "costs",
          "security",
          "quality",
          "watchdog",
          "memory",
          "messages",
          "rollback"
        ]
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-os.local/schemas/social-account.schema.json",
  "title": "AG OS Social Account",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "accountId",
    "recordType",
    "projectId",
    "clientId",
    "engagementId",
    "platform",
    "handle",
    "handleStatus",
    "accountState",
    "connectionMode",
    "oauthStatus",
    "credentialRefId",
    "credentialStorageStatus",
    "credentialsStoredInRepo",
    "postingMode",
    "ownerApprovalRequired",
    "livePostingBlocked",
    "schedulingBlocked",
    "analyticsBlocked",
    "dmCommentsBlocked",
    "n8nActivationBlocked",
    "paidToolsAllowed",
    "permissions",
    "blockedActions",
    "nextRequiredApproval",
    "sourceRecords",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../../schemas/social-account.schema.json" },
    "accountId": { "type": "string", "pattern": "^social-account-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "recordType": { "type": "string", "const": "social_account" },
    "projectId": { "type": "string", "pattern": "^project-[a-z0-9-]+$" },
    "clientId": { "type": "string", "pattern": "^client-[a-z0-9-]+$" },
    "engagementId": { "type": "string", "pattern": "^engagement-[a-z0-9-]+$" },
    "platform": { "type": "string", "enum": ["Instagram", "TikTok", "YouTube Shorts", "LinkedIn"] },
    "handle": { "type": "string", "minLength": 1 },
    "handleStatus": { "type": "string", "enum": ["public_handle_provided", "pending_owner_input", "not_provided"] },
    "accountState": {
      "type": "string",
      "enum": [
        "not_connected",
        "access_requested",
        "oauth_ready",
        "connected_draft_only",
        "approved_for_single_publish",
        "approved_for_scheduling",
        "approved_for_live_posting",
        "revoked",
        "expired",
        "blocked"
      ]
    },
    "connectionMode": { "type": "string", "enum": ["draft_only", "connected_draft_only", "live_posting"] },
    "oauthStatus": { "type": "string", "enum": ["not_started", "blocked", "ready_after_approval", "connected", "revoked", "expired"] },
    "credentialRefId": { "type": ["string", "null"], "pattern": "^credential-ref-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "credentialStorageStatus": { "type": "string", "enum": ["none", "planned", "approved_reference", "active_reference", "revoked"] },
    "credentialsStoredInRepo": { "type": "boolean", "const": false },
    "postingMode": { "type": "string", "enum": ["draft_only", "single_publish_approval_required", "scheduling_approval_required", "live_posting_approval_required"] },
    "ownerApprovalRequired": { "type": "boolean", "const": true },
    "livePostingBlocked": { "type": "boolean" },
    "schedulingBlocked": { "type": "boolean" },
    "analyticsBlocked": { "type": "boolean" },
    "dmCommentsBlocked": { "type": "boolean" },
    "n8nActivationBlocked": { "type": "boolean" },
    "paidToolsAllowed": { "type": "boolean", "const": false },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "excluded"],
      "properties": {
        "requested": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "excluded": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "blockedActions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } },
    "nextRequiredApproval": { "type": "string", "minLength": 1 },
    "sourceRecords": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

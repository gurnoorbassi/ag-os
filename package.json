{
  "name": "ag-os",
  "version": "0.0.0",
  "private": true,
  "description": "AG Digitalz OS foundation: docs, schemas, safety rules, and validation only.",
  "type": "module",
  "scripts": {
    "dashboard:build": "node scripts/build-dashboard.mjs",
    "dashboard:check": "node scripts/check-dashboard.mjs",
    "boot:check": "node scripts/boot-check.mjs",
    "approvals:stale": "node scripts/manage-stale-approvals.mjs --list",
    "proof:write": "node scripts/process-runtime-proof-writer.mjs",
    "connector:preflight": "node scripts/process-connector-preflight.mjs",
    "memory:load": "node scripts/load-accepted-lessons.mjs",
    "lessons:promote": "node scripts/process-lesson-promotion.mjs",
    "archetypes:propose": "node scripts/process-archetype-update-proposal.mjs",
    "security:scan": "node scripts/scan-secrets.mjs",
    "production:check": "node scripts/check-production-readiness.mjs",
    "production:check:coordinator": "node scripts/check-production-readiness.mjs --record .codex/production/production-readiness-ag-os-coordinator-v1.json",
    "live:start": "node scripts/live-server.mjs",
    "validate": "node scripts/validate-foundation.mjs && node scripts/check-dashboard.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
